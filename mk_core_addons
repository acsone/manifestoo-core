#!/usr/bin/env python3

# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "manifestoo-core",
# ]
# ///

import os
import subprocess
import tempfile
import time
from pathlib import Path
from typing import Iterator, Iterable, Mapping, Optional

from manifestoo_core.addon import Addon, AddonNotFound
from manifestoo_core.odoo_series import OdooEdition

SERIES = [
    # branch,  enterprise, target
    ("19.0", True, None),
    ("18.0", True, None),
    ("17.0", True, None),
    ("16.0", True, None),
    # ("15.0", True, None),
    # ("14.0", True, None),
    # ("13.0", True, None),
    # ("12.0", True, None),
    # ("11.0", True, None),
    # ('10.0', True, None),
    # ('9.0', True, None),
    # ('8.0', False, None),
]


def _list_addons(addons_dirs: Iterable[Path]) -> Iterator[str]:
    for addons_dir in addons_dirs:
        for addon_dir in addons_dir.iterdir():
            try:
                yield Addon.from_addon_dir(addon_dir, allow_not_installable=True).name
            except AddonNotFound:
                pass


def _write_addons_list(addons_dirs: Iterable[Path], suffix: str) -> None:
    list_path = (
        Path(__file__).parent
        / "src"
        / "manifestoo_core"
        / "core_addons"
        / f"addons-{suffix}.txt"
    )
    with list_path.open("w") as f:
        print("# generated on", time.asctime(), file=f)
        for addon_name in sorted(_list_addons(addons_dirs)):
            print(addon_name, file=f)


def check_call(*cmd: str, env: Optional[Mapping[str, str]] = None) -> None:
    print(" ".join(cmd))
    subprocess.check_call(cmd, env=env)


def check_output(*cmd: str) -> str:
    print(" ".join(cmd))
    return subprocess.check_output(cmd, text=True)


def main() -> None:
    for branch, enterprise, target in SERIES:
        with tempfile.TemporaryDirectory() as tmpdir:
            check_call(
                "git",
                "clone",
                "--depth=1",
                "--branch",
                branch,
                "https://github.com/odoo/odoo",
                tmpdir,
            )
            _write_addons_list(
                [
                    Path(tmpdir)
                    / ("openerp" if float(branch) < 10 else "odoo")
                    / "addons",
                    Path(tmpdir) / "addons",
                ],
                f"{target or branch}-{OdooEdition.CE.value}",
            )
        if enterprise:
            with tempfile.TemporaryDirectory() as tmpdir:
                # Support a differrent GitHub token to access odoo/enterprise.
                # This is necessary for the update-core-addons GitHub workflow.
                if os.getenv("ODOO_ENTERPRISE_GH_TOKEN"):
                    print(
                        "Found ODOO_ENTERPRISE_GH_TOKEN, using it to clone odoo/enterprise"
                    )
                    env = dict(
                        os.environ,
                        GH_TOKEN=os.environ["ODOO_ENTERPRISE_GH_TOKEN"],
                    )
                else:
                    env = os.environ
                check_call(
                    "gh",
                    "repo",
                    "clone",
                    "odoo/enterprise",
                    tmpdir,
                    "--",
                    "--depth=1",
                    "--branch",
                    branch,
                    env=env,
                )
                _write_addons_list(
                    [Path(tmpdir)],
                    f"{target or branch}-{OdooEdition.EE.value}",
                )


def pr():
    assert Path("news").is_dir()
    check_call("git", "add", "src/manifestoo_core/core_addons")

    # Check if there are meaningful changes (not just date changes)
    diff_output = check_output(
        "git", "diff", "--cached", "src/manifestoo_core/core_addons"
    )

    # Filter out lines that only contain date changes
    meaningful_changes = [
        line
        for line in diff_output.splitlines()
        if line.startswith(("+", "-"))
        and not line.startswith(("+++", "---"))
        and "# generated on" not in line
    ]

    if not meaningful_changes:
        print(
            "No meaningful changes detected (only date changes). Skipping PR creation."
        )
        return

    check_call("git", "checkout", "-B", "update-core-addon-lists")
    check_call("git", "commit", "-m", "Update core addon lists")
    check_call("git", "push", "-f", "origin")
    output = check_output(
        "gh", "pr", "create", "--title", "Update core addon lists", "--body", ""
    )
    pr = output.strip().rpartition("/")[-1]
    news_path = Path("news") / f"{pr}.feature"
    news_path.write_text("Update core addon lists.\n")
    check_call("git", "add", str(news_path))
    check_call("git", "commit", "--amend", "--no-edit")
    check_call("git", "push", "-f")


if __name__ == "__main__":
    main()
    pr()
